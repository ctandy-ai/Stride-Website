admin/config.yml
backend:
  name: github
  repo: YOUR-GITHUB-USERNAME/stride-landing
  branch: main
 
media_folder: images
 
collections:
  - name: pages
    label: Pages
    files:
      - name: home
        label: Home Page
        file: stride-v13.html
        fields:
          - { label: Hero Headline, name: hero_h, widget: string }
          - { label: Hero Motto, name: hero_motto, widget: string }
          - { label: Hero Sub Copy, name: hero_sub, widget: text }
          - { label: Pricing — Accelerator Weekly Rate, name: price_main, widget: string }
          - { label: Pricing — Initial Consult Rate, name: price_consult, widget: string }
          - { label: Address Line, name: address, widget: string }
          - { label: Phone Number, name: phone, widget: string }
